# AI Factory - Environment Variables Example
# Copiar este archivo a .env y completar con tus valores

# ===========================================
# OPENAI (Opcional - puedes usar solo Azure)
# ===========================================
OPENAI_API_KEY=sk-tu-api-key-aqui

# ===========================================
# AZURE OPENAI (Recomendado para empresas)
# ===========================================
AZURE_OPENAI_ENDPOINT=https://tu-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=tu-azure-key-aqui
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# ===========================================
# GITHUB (Para automatizaciones)
# ===========================================
GITHUB_TOKEN=ghp_tu_token_de_github_aqui

# ===========================================
# CONFIGURACIÓN DEL PROYECTO
# ===========================================
PROJECT_NAME=mi-proyecto-ia
LOG_LEVEL=INFO

# ===========================================
# BASE DE DATOS
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ===========================================
# OTROS SERVICIOS
# ===========================================
# SMTP_EMAIL=tu-email@dominio.com
# SMTP_PASSWORD=tu-password
# SLACK_WEBHOOK=https://hooks.slack.com/...
